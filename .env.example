# 飞书应用配置
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPTION_KEY=

# AI 模型配置
# 可选提供商：openai, deepseek, claude, moonshot, qwen, zhipu, ollama, custom
AI_MODEL_PROVIDER=deepseek

# 各模型 API 密钥（根据使用的提供商填写对应的密钥）
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
MOONSHOT_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=

# 自定义模型配置（当 AI_MODEL_PROVIDER=custom 时使用）
CUSTOM_API_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_API_MODEL=

# 服务器配置
PORT=3000

# 环境
NODE_ENV=development
